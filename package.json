{
  "name": "campusweb-pages",
  "version": "2.0.3",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "test:security": "npm exec --min-release-age=0 --yes --package vitest -- vitest run Tests/security/input-security.test.ts",
    "security:audit": "npm audit --audit-level=moderate",
    "security:signatures": "npm_config_min_release_age=0 npm audit signatures",
    "security:outdated": "npm_config_min_release_age=0 npm outdated",
    "security:weekly": "npm run check && npm run build && npm run security:audit && npm run test:security",
    "deploy": "npm run build && wrangler pages deploy .svelte-kit/cloudflare"
  },
  "devDependencies": {
    "@phosphor-icons/web": "^2.1.2",
    "@playwright/test": "^1.60.0",
    "@sveltejs/adapter-cloudflare": "^7.2.8",
    "@sveltejs/adapter-static": "^3.0.10",
    "@sveltejs/kit": "^2.60.1",
    "@sveltejs/vite-plugin-svelte": "^7.0.0",
    "@types/event-calendar__core": "^5.6.0",
    "@types/event-calendar__day-grid": "^3.4.1",
    "@types/event-calendar__list": "^3.4.1",
    "@types/event-calendar__time-grid": "^3.4.1",
    "svelte": "^5.55.0",
    "svelte-check": "^4.0.0",
    "tslib": "^2.6.0",
    "typescript": "^5.0.0",
    "vite": "^8.0.10",
    "wrangler": "^4.93.1"
  },
  "dependencies": {
    "@event-calendar/core": "^3.12.0",
    "@event-calendar/day-grid": "^3.12.0",
    "@event-calendar/interaction": "^3.12.0",
    "@event-calendar/list": "^3.12.0",
    "@event-calendar/time-grid": "^3.12.0",
    "@tsndr/cloudflare-worker-jwt": "^2.4.0",
    "@types/sortablejs": "^1.15.9",
    "fast-xml-parser": "^5.3.4",
    "ical.js": "^2.2.1",
    "jose": "^6.2.3",
    "leaflet": "^0.7.3",
    "sortablejs": "^1.15.7"
  },
  "overrides": {
    "cookie": "^0.7.0",
    "esbuild": "^0.25.0",
    "svelte": "^5.55.0"
  }
}
