# Cloudflare Pages Configuration
# Copy this file to wrangler.toml and fill in your values.

name = "campusweb"
compatibility_date = "2024-01-01"
pages_build_output_dir = ".svelte-kit/cloudflare"

# Uncomment and configure if using D1 database
# [[d1_databases]]
# binding = "DB"
# database_name = "your-database-name"
# database_id = "YOUR_DATABASE_ID_HERE"

# Uncomment and configure if using KV namespace
# [[kv_namespaces]]
# binding = "CACHE"
# id = "YOUR_KV_NAMESPACE_ID_HERE"

[vars]
JWT_SECRET = "change-this-to-a-secure-random-string"
PRIVATE_GOOGLE_SHEETS_URL = "YOUR_GOOGLE_SHEETS_CSV_URL_HERE"
