# Cloudflare Pages Configuration
# Copy this file to wrangler.toml and fill in your values.

name = "campusweb"
compatibility_date = "2024-01-01"
pages_build_output_dir = ".svelte-kit/cloudflare"

# 🗄️ KV Namespace for Story & Club persistence
[[kv_namespaces]]
binding = "STORIES_KV"
id = "YOUR_KV_NAMESPACE_ID_HERE"

# 🖼️ R2 Bucket for Image Hosting
[[r2_buckets]]
binding = "IMAGES_BUCKET"
bucket_name = "YOUR_BUCKET_NAME_HERE"

# 📧 Email Binding (Workers Send Email)
# Requires setup in Cloudflare Dashboard
send_email = [
  { name = "EMAIL" }
]

[vars]
PRIVATE_TELEGRAM_BOT_TOKEN = "YOUR_BOT_TOKEN"
PRIVATE_TELEGRAM_CHAT_ID = "YOUR_ADMIN_CHAT_ID"
PRIVATE_SITE_URL = "https://campusweb.pages.dev"
PRIVATE_EMAIL_SENDER = "campusweb@yourdomain.com"
PRIVATE_VIRUSTOTAL_API_KEY = "YOUR_VT_API_KEY"
